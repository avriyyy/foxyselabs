{
  "name": "foxyselabs",
  "version": "0.1.0",
  "private": true,
  "description": "Self-hosted AI Agent platform (Claude Desktop for the web). MIT licensed.",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev:web": "pnpm --filter @foxyselabs/web dev",
    "dev:gateway": "pnpm --filter @foxyselabs/gateway dev",
    "dev:agent": "pnpm --filter @foxyselabs/agent dev",
    "build:web": "pnpm --filter @foxyselabs/web build",
    "build:gateway": "pnpm --filter @foxyselabs/gateway build",
    "build:agent": "pnpm --filter @foxyselabs/agent build",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:reset": "docker compose down -v && docker compose up -d",
    "db:migrate": "docker compose exec -T postgres psql -U foxyse -d foxyse -f /docker-entrypoint-initdb.d/0001_init.sql"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
