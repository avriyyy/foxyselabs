# ============================================================================
# FoxyseLabs v2 — Environment configuration
# Copy to .env and fill in the values.
# ============================================================================

# ---------- Database ----------
POSTGRES_DB=foxyse
POSTGRES_USER=foxyse
POSTGRES_PASSWORD=foxyselabs
POSTGRES_PORT=5432
DATABASE_URL=postgresql://foxyse:foxyselabs@localhost:5432/foxyse

# ---------- Redis ----------
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# ---------- Gateway (Go) ----------
GATEWAY_PORT=8080
# 32+ random bytes (e.g. `openssl rand -hex 32`)
JWT_SECRET=change-this-to-a-random-32-byte-hex-string
# 32 random bytes, base64 encoded (e.g. `openssl rand -base64 32`)
ENCRYPTION_KEY=change-this-to-a-base64-encoded-32-byte-key
# Used to issue cookies / CORS
PUBLIC_BASE_URL=http://localhost:3000
# Internal — gateway calls agent over docker network
AGENT_SERVICE_URL=http://agent:8000

# ---------- Agent (Python) ----------
AGENT_PORT=8000
# Public-facing port for the Next.js web app
PUBLIC_PORT=3000

# ---------- LLM (server-side defaults, optional) ----------
# Users can override per-account via BYOK in settings (encrypted at rest).
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Base URL of an Ollama instance reachable from the agent container.
# For local Ollama on the host, use http://host.docker.internal:11434
OLLAMA_BASE_URL=

# Xiaomi MiMo (OpenAI-compatible). https://api.xiaomimimo.com/v1
# Models: mimo-v2-flash, mimo-v2-omni, mimo-v2-pro, mimo-v2.5, mimo-v2.5-pro
MIMO_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_API_KEY=

# ---------- Sandbox ----------
SANDBOX_IMAGE=ubuntu:24.04
SANDBOX_TIMEOUT_SEC=120
SANDBOX_MEMORY_LIMIT=512m
SANDBOX_CPU_LIMIT=1.0

# ---------- Web (Next.js) ----------
# Public URL the browser uses to reach the gateway
NEXT_PUBLIC_GATEWAY_URL=http://localhost:8080
