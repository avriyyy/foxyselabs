# ============================================================================
# FoxyseLabs v2 — Environment configuration (Claude Code adapter edition)
# Copy to .env and fill in the values.
# ============================================================================

# ---------- Database ----------
POSTGRES_DB=foxyse
POSTGRES_USER=foxyse
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5432
DATABASE_URL=postgresql://foxyse:changeme@localhost:5432/foxyse

# ---------- Redis ----------
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# ---------- Gateway (Go) ----------
GATEWAY_PORT=8080
PUBLIC_BASE_URL=http://localhost:3000

# First-time admin (auto-created on first /setup POST)
ADMIN_EMAIL=admin@localhost
ADMIN_NAME=Admin
ADMIN_PASSWORD=changeme-on-first-login-please

# ---------- Agent (Python + Claude Code) ----------
AGENT_PORT=8000
PUBLIC_PORT=3000

# Claude Code model. With MiMo Anthropic-compatible endpoint: mimo-v2-flash.
# For real Anthropic: claude-sonnet-4-5, claude-opus-4, etc.
CLAUDE_MODEL=mimo-v2-flash

# Claude Code API key (any Anthropic-compatible provider).
# Leave blank in example; set to your real key in .env.
ANTHROPIC_API_KEY=
# Anthropic-compatible endpoint. Examples:
#   https://api.anthropic.com                                 (real Anthropic)
#   https://api.xiaomimimo.com/anthropic                      (MiMo, supports OpenAI + Anthropic formats)
ANTHROPIC_BASE_URL=https://api.xiaomimimo.com/anthropic

# ---------- Sandbox ----------
SANDBOX_IMAGE=foxyselabs-sandbox:latest
# Host path that the agent's /data/workspaces maps to. The agent
# container sees /data/workspaces/* (mounted from this path on the
# host). When spawning sandbox containers, the agent translates
# /data/workspaces/* back to the host path so dockerd can resolve it.
WORKSPACE_HOST_ROOT=/data/workspaces

# ---------- Web (Next.js) ----------
# Browser-reachable gateway URL (must be reachable from the user's machine).
# For VPS deployment, set this to http://<VPS_IP>:8080
NEXT_PUBLIC_GATEWAY_URL=http://localhost:8080
